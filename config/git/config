[user]
    name = boenshao
    email = boenshao@gmail.com

[core]
    editor = nvim
    pager = delta

[init]
	defaultBranch = main

[diff]
    colorMoved = default

[merge]
    conflictStyle = zdiff3

[interactive]
    diffFilter = delta --color-only

[delta]
    side-by-side = false
    line-numbers = true
    map-styles = bold purple => syntax magenta, bold cyan => syntax blue

[diff "sopsdiffer"]
    textconv = "sops decrypt"

[includeIf "gitdir:~/repo-work/"]
    path = ~/repo-work/.gitconfig
